# ══════════════════════════════════════════════════════════
#  ThreatPilot AI — .gitignore
#  CRITICAL: Never commit secrets, keys, or node_modules
# ══════════════════════════════════════════════════════════

# ── Environment variables (NEVER COMMIT) ──
.env
.env.local
.env.production
.env.staging
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example

# ── Node modules ──
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build outputs ──
dist/
build/
.next/
out/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ──
coverage/
.nyc_output/
junit.xml

# ── Runtime data ──
pids/
*.pid
*.seed
*.pid.lock

# ── Cache ──
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ── Package manager locks ──
# We use `npm install` on Render (no lock file needed)
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Vercel / Render / deployment ──
.vercel
.render

# ── SSL certs (never commit private keys) ──
*.pem
*.key
*.crt
*.p12
*.pfx
