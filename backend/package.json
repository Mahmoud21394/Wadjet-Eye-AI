{
  "name": "threatpilot-backend",
  "version": "3.1.0",
  "description": "ThreatPilot AI — Production-Grade Threat Intelligence Backend (Node.js + Express + Supabase)",
  "main": "server.js",
  "author": "ThreatPilot AI Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "health": "node -e \"require('http').get('http://localhost:4000/health', r => { let d=''; r.on('data',c=>d+=c); r.on('end',()=>{ const h=JSON.parse(d); console.log('Status:', h.status, '| DB:', h.db, '| Uptime:', h.uptime_s+'s'); process.exit(h.status==='OK'?0:1); }); }).on('error',e=>{ console.error('Health check failed:', e.message); process.exit(1); });\"",
    "lint": "eslint . --ext .js --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "validate-env": "node -e \"const r=['SUPABASE_URL','SUPABASE_SERVICE_KEY','SUPABASE_ANON_KEY']; const m=r.filter(k=>!process.env[k]); if(m.length){console.warn('Warning: Missing env vars: '+m.join(', ')+'. DB-dependent routes may fail.');} else { console.log('All required env vars present ✓'); }\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "neo4j-driver": "^5.27.0",
    "node-fetch": "^2.7.0",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "puppeteer": "^22.15.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0",
    "socket.io": "^4.6.2",
    "socks-proxy-agent": "^8.0.5",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js",
      "services/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": "off",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes/",
      "middleware/",
      "services/",
      "config/",
      "database/"
    ],
    "ext": "js,json",
    "ignore": [
      "tests/",
      "scripts/",
      "node_modules/"
    ],
    "delay": "1000"
  }
}
