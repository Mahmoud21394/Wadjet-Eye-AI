# ══════════════════════════════════════════════════════════════
#  Wadjet-Eye AI — Environment Variables v5.4
#  File: backend/.env.example
#
#  INSTRUCTIONS:
#  1. Copy this file:   cp backend/.env.example backend/.env
#  2. Fill in your API keys below
#  3. NEVER commit .env to git (it's in .gitignore)
#  4. For Render deployment: add each variable in the Render dashboard
#     (Environment tab of your web service)
#
#  v5.4 JWT MIGRATION:
#  Supabase migrated from Legacy JWT Secret to new JWT Signing Keys.
#  Use the new "publishable" key for SUPABASE_ANON_KEY and the new
#  "secret" key for SUPABASE_SERVICE_KEY.
#
#  OLD format (deprecated, still works until revoked):
#    SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#    SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
#  NEW format (recommended):
#    SUPABASE_ANON_KEY=sb_publishable_<your-key>
#    SUPABASE_SERVICE_KEY=sb_secret_<your-key>
#
#  Get new keys from: Supabase Dashboard → Settings → API → API Keys
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Frontend Origins (CORS whitelist) ─────────────────────────
# Add your frontend URL here. Multiple URLs comma-separated.
FRONTEND_URL=https://your-frontend.vercel.app
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://www.genspark.ai,http://localhost:3000,http://localhost:5500

# ── Supabase (REQUIRED) ────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Settings → API → API Keys
SUPABASE_URL=https://your-project-id.supabase.co
#
# OPTION A — New key format (recommended, use after Supabase JWT migration):
SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here
SUPABASE_SERVICE_KEY=sb_secret_your-secret-key-here
#
# OPTION B — Legacy key format (still works until explicitly revoked):
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Secret ────────────────────────────────────────────────
# MUST match your Supabase project's current JWT secret exactly.
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# NOTE: This is the signing key used to verify user access tokens.
#       Only update this value if/when you rotate keys in Supabase.
JWT_SECRET=your-jwt-secret-here

# ── Token TTL ─────────────────────────────────────────────────
ACCESS_TOKEN_TTL=900           # 15 minutes (seconds)
REFRESH_TOKEN_EXPIRY_DAYS=30   # 30 days

# ── Default Tenant (for shared/demo data) ─────────────────────
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ══════════════════════════════════════════════════════════════
#  AI PROVIDERS (at least one required for AI features)
# ══════════════════════════════════════════════════════════════

# OpenAI GPT-4o (PRIMARY — recommended)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Google Gemini 2.0 Flash (FALLBACK)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (OPTIONAL)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Local Ollama (OPTIONAL — for air-gapped deployments)
# Install: https://ollama.ai — then: ollama pull qwen3:8b
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b

# ══════════════════════════════════════════════════════════════
#  THREAT INTELLIGENCE APIS
# ══════════════════════════════════════════════════════════════

# AlienVault OTX (FREE — required for actor/campaign data)
# Get from: https://otx.alienvault.com/api
OTX_API_KEY=your-otx-api-key-here

# AbuseIPDB (FREE tier: 1000 req/day — for IP reputation)
# Get from: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your-abuseipdb-key-here

# VirusTotal (FREE tier: 4 req/min — for file/URL/IP enrichment)
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-virustotal-key-here

# Shodan (PAID — for internet exposure scanning)
# Get from: https://account.shodan.io/
SHODAN_API_KEY=your-shodan-key-here

# PhishTank (FREE — for phishing URL feed)
# Get from: https://www.phishtank.com/api_info.php
# Leave empty to use anonymous access (rate-limited)
# PHISHTANK_API_KEY=your-phishtank-key-here

# IPInfo (FREE tier: 50k req/month — for GeoIP)
# Get from: https://ipinfo.io/account/token
# Leave empty to use free unauthenticated access
# IPINFO_API_KEY=your-ipinfo-key-here

# ══════════════════════════════════════════════════════════════
#  INGESTION SCHEDULE (minutes — all optional, have defaults)
# ══════════════════════════════════════════════════════════════
OTX_INTERVAL_MIN=60           # AlienVault OTX — every 60 min
URLHAUS_INTERVAL_MIN=15       # Abuse.ch URLhaus — every 15 min
THREATFOX_INTERVAL_MIN=30     # Abuse.ch ThreatFox — every 30 min
ABUSEIPDB_INTERVAL_MIN=120    # AbuseIPDB — every 2 hours
MALWAREBAZAAR_MIN=30          # MalwareBazaar — every 30 min
FEODO_INTERVAL_MIN=15         # Feodo Tracker — every 15 min
CISA_INTERVAL_MIN=360         # CISA KEV — every 6 hours
NVD_INTERVAL_MIN=360          # NVD CVEs — every 6 hours
PHISHTANK_MIN=60              # PhishTank — every 1 hour
OPENPHISH_MIN=30              # OpenPhish — every 30 min
MISP_INTERVAL_MIN=240         # MISP CIRCL — every 4 hours
NEWS_INTERVAL_MIN=30          # Cyber news RSS — every 30 min
ENRICH_INTERVAL_MIN=10        # IOC enrichment — every 10 min
EXPOSURE_INTERVAL_MIN=15      # Exposure correlation — every 15 min

# ══════════════════════════════════════════════════════════════
#  SOAR / NOTIFICATIONS (all optional)
# ══════════════════════════════════════════════════════════════

# Slack webhook for SOAR alert notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Generic webhook for SOAR automation engine
# SOAR_WEBHOOK_URL=https://your-soar-webhook.example.com

# Email notifications (SendGrid)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Email notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=alerts@yourdomain.com

# ══════════════════════════════════════════════════════════════
#  INTEGRATIONS (all optional)
# ══════════════════════════════════════════════════════════════

# Jira (for automatic ticket creation from SOAR)
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=your@email.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=SOC

# ServiceNow (for ITSM integration)
# SERVICENOW_URL=https://yourinstance.service-now.com
# SERVICENOW_USER=admin
# SERVICENOW_TOKEN=your-servicenow-token

# PagerDuty (for on-call escalation)
# PAGERDUTY_API_KEY=your-pagerduty-key
# PAGERDUTY_SERVICE_ID=your-service-id

# ══════════════════════════════════════════════════════════════
#  ORGANIZATION (used in Shodan search queries)
# ══════════════════════════════════════════════════════════════
ORG_NAME=YourOrganization

# ══════════════════════════════════════════════════════════════
#  NVD API (optional — improves CVE ingestion rate limits)
#  Get from: https://nvd.nist.gov/developers/request-an-api-key
# ══════════════════════════════════════════════════════════════
# NVD_API_KEY=your-nvd-api-key-here
